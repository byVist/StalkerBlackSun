<Window x:Class="StalkerBlackSun.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="S.T.A.L.K.E.R. Black Sun" Height="600" Width="900" WindowStartupLocation="CenterScreen">
    <Grid Background="#FF1B1B1B">

        <StackPanel x:Name="MainMenu" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="S.T.A.L.K.E.R." FontSize="48" FontWeight="Bold" Foreground="Orange" HorizontalAlignment="Center" FontFamily="Impact"/>
            <TextBlock Text="ЧЕРНОЕ СОЛНЦЕ" FontSize="36" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" FontFamily="Impact"/>
            <Button Content="НАЧАТЬ ПОИСК АРТЕФАКТА" Click="StartGame_Click" Background="Transparent" Foreground="LightGray" BorderThickness="0" FontSize="16" Margin="0,20,0,0" Cursor="Hand"/>
            <Label x:Name="lblAuthor" Content="Автор: Замаратский Данил Максимович" FontSize="16" Foreground="Gray" HorizontalAlignment="Center" Margin="0,40,0,0"/>
        </StackPanel>

        <StackPanel x:Name="GameScreen" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <Border BorderBrush="Orange" BorderThickness="1" Margin="10" CornerRadius="5">
                <Image x:Name="imgScene" Width="600" Height="300" Stretch="UniformToFill"/>
            </Border>

            <TextBlock x:Name="txtScene" FontSize="18" Foreground="White" TextWrapping="Wrap" 
               TextAlignment="Center" Margin="10" Width="650" Height="100"/>

            <TextBlock x:Name="txtLog" Text="— Хроника похода —" FontSize="11" Foreground="DimGray" TextAlignment="Center" Margin="5"/>

            <StackPanel x:Name="ChoicePanel" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="btnLeft" Width="220" Height="50" Margin="10" Click="GameButton_Click" Background="#FF333333" Foreground="White"/>
                <Button x:Name="btnRight" Width="220" Height="50" Margin="10" Click="GameButton_Click" Background="#FF333333" Foreground="White"/>
            </StackPanel>

            <Button x:Name="btnNext" Content="ДАЛЕЕ" Visibility="Collapsed" Width="220" Height="50" Margin="10" Click="GameButton_Click" Background="#FF444444" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
